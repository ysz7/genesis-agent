# ── genesis-agent secrets ──────────────────────────────────────────────────────
# Copy to .env and fill in. Choosing a provider is the ONLY code-free switch.

# One of: openai | anthropic | openrouter | ollama
PROVIDER=openai

# Model id for the chosen provider.
#   openai      → gpt-4o-mini, gpt-4o, o4-mini, …
#   anthropic   → claude-haiku-4-5, claude-sonnet-4-6, claude-opus-4-8
#   openrouter  → openai/gpt-4o-mini, anthropic/claude-sonnet-4-6, …
#   ollama      → any pulled model, e.g. llama3.1:8b, qwen2.5
MODEL=gpt-4o-mini

# API key for the chosen provider (not needed for ollama).
API_KEY=

# Override the endpoint. Auto-set for openrouter/ollama; leave blank otherwise.
# BASE_URL=

# ── Observability (optional) ─────────────────────────────────────────────────
# Logfire tracing: install with `uv sync --extra obs`, then set the token —
# every run (model calls, tool calls) appears in your Logfire project.
# LOGFIRE_TOKEN=

# ── HTTP server (--serve) ────────────────────────────────────────────────────
# Optional bearer token. When set, every endpoint except /health requires
#   Authorization: Bearer <token>
# Leave unset for no auth (fine on a localhost-only bind, the default).
# SERVER_TOKEN=

# ── Messaging gateways (optional) ────────────────────────────────────────────
# Built into the core; a channel stays dormant until enabled in settings.yaml
# (gateways:) AND its token is set here. See the README "Gateways" section.
# Telegram (long-poll locally, or webhook on --serve):
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_OWNER_ID=          # your numeric id — always allowed; runs /allow etc.
# WhatsApp (Meta Cloud API — webhook-only, needs --serve + a public URL):
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_ID=
# WHATSAPP_VERIFY_TOKEN=      # the handshake string you choose in the Meta dashboard
# Verifies inbound webhooks on --serve (set the same value when registering them):
# WEBHOOK_SECRET=

# ── Ollama (local, offline, no key) ──────────────────────────────────────────
# PROVIDER=ollama
# MODEL=llama3.1:8b
# BASE_URL=http://localhost:11434/v1
