# ── Scheduling genesis-agent (external, 24/7) ────────────────────────────────────
# The agent HAS a built-in scheduler: ask it in chat ("summarize HN every 2
# hours" → schedule_task / list_scheduled / cancel_scheduled), or add jobs in the
# menu's Scheduler. Those jobs fire in the background while a long-lived process
# is up — a gateway bot or the HTTP server (`--serve`) — and results are
# delivered to all channels.
#
# THIS file is for the other case: recurring runs with NO long-lived process
# (no bot, no server, terminal closed). An external scheduler drives one-shot
# runs. Pick your platform below.
#
# Use scripts/run.sh / scripts/run.ps1 (they cd into the folder, find uv, and run
# `agent <task>`). Do NOT use start.cmd for scheduling — it ends with `pause`.
# Replace the path with this folder's absolute path.

# ── cron (Linux/macOS) ───────────────────────────────────────────────────────
# Edit with: crontab -e
#
#   # every hour, on the hour
#   0 * * * * /path/to/agent-folder/scripts/run.sh "Run the hourly briefing" >> /path/to/agent-folder/workspace/cron.log 2>&1
#
#   # every minute (e.g. a trading agent)
#   * * * * * /path/to/agent-folder/scripts/run.sh "Check positions and act" >> /path/to/agent-folder/workspace/cron.log 2>&1


# ── systemd timer (Linux) ────────────────────────────────────────────────────
# /etc/systemd/system/genesis-agent.service
#
#   [Unit]
#   Description=genesis-agent one-shot run
#   [Service]
#   Type=oneshot
#   WorkingDirectory=/path/to/agent-folder
#   ExecStart=/path/to/agent-folder/scripts/run.sh "Run the hourly briefing"
#
# /etc/systemd/system/genesis-agent.timer
#
#   [Unit]
#   Description=Run genesis-agent hourly
#   [Timer]
#   OnCalendar=hourly
#   Persistent=true
#   [Install]
#   WantedBy=timers.target
#
# Enable: systemctl enable --now genesis-agent.timer


# ── Windows Task Scheduler ───────────────────────────────────────────────────
# Run in PowerShell (adjust the path and schedule). $root is the agent folder:
#
#   $root    = "C:\path\to\agent-folder"
#   $action  = New-ScheduledTaskAction -Execute "powershell.exe" `
#       -Argument "-NoProfile -ExecutionPolicy Bypass -File `"$root\scripts\run.ps1`" `"Run the hourly briefing`""
#   $trigger = New-ScheduledTaskTrigger -Daily -At 9am
#   Register-ScheduledTask -TaskName "genesis-agent" -Action $action -Trigger $trigger
#
# Run it now to test:  Start-ScheduledTask -TaskName "genesis-agent"
# Remove it:           Unregister-ScheduledTask -TaskName "genesis-agent" -Confirm:$false
