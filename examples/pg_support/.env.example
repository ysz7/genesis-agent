# Copy to .env and fill in.  cp .env.example .env

# Provider for chat + embeddings (any OpenAI-compatible one works).
PROVIDER=openai
MODEL=gpt-4o-mini
API_KEY=sk-...

# The one Postgres (with pgvector) this agent talks to.
# Matches docker-compose.yml below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support

# --- Local, no-API-key alternative (Ollama) -------------------------------
# PROVIDER=ollama
# MODEL=llama3.1:8b
# BASE_URL=http://localhost:11434/v1
# embed_model in settings.yaml → nomic-embed-text, and vector(768) in schema.sql
